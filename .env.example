# Location Configuration
LATITUDE=36.1627
LONGITUDE=-86.7816
LOCATION_NAME=Nashville, TN

# LLM Configuration
# Option 1: Ollama (local, open-source)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434  # Your Ollama server
OLLAMA_MODEL=llama3.2:3b  # Fits in 4-6GB VRAM

# Option 2: OpenAI-compatible API (optional)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=http://your-api-server:8000/v1
# OPENAI_MODEL=gpt-3.5-turbo

# Database
DATABASE_PATH=./data/weather.db

# Update Intervals
UPDATE_INTERVAL=10  # minutes
ML_RETRAIN_INTERVAL=24  # hours
HISTORY_RETENTION_DAYS=365

# Logging
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
