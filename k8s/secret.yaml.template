# OPTIONAL - Only needed if using OpenAI-compatible API provider
# If using Ollama, you can skip creating this secret
---
apiVersion: v1
kind: Secret
metadata:
  name: weather-secrets
  namespace: weather-forecast
type: Opaque
stringData:
  # Only needed if LLM_PROVIDER=openai
  OPENAI_API_KEY: "your_api_key_here"
